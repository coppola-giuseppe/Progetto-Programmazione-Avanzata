<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unipi.progetto_applicazione.InitializeController">
   <content>
      <VBox alignment="CENTER" spacing="20.0" styleClass="initialize_background" stylesheets="@style/initialize.css">
          <children>
              <Label styleClass="text-shadow" stylesheets="@style/initialize.css" text="Database initializer" textFill="WHITE">
               <font>
                  <Font name="System Bold Italic" size="48.0" />
               </font>
            </Label>
              <Button fx:id="btnInitialize" onAction="#initializePressed" text="Click here to initialize">
               <font>
                  <Font size="18.0" />
               </font></Button>
            <Label fx:id="progressLabel" managed="false" styleClass="text-shadow" stylesheets="@style/initialize.css" text="Initializing the database: it should take 1-2 minutes, please wait..." textFill="WHITE">
               <font>
                  <Font size="18.0" />
               </font></Label>
            <ProgressBar fx:id="progressBar" managed="false" prefWidth="200.0" progress="0.0" />
            <Hyperlink fx:id="homeLink" onAction="#backToHome" stylesheets="@style/initialize.css" text="Return to the homepage">
               <font>
                  <Font size="24.0" />
               </font></Hyperlink>
          </children>
          <padding>
              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
          </padding>
      </VBox>
   </content>
</ScrollPane>
